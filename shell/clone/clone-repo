#!/usr/bin/env bash

set -e

# This is used for the Hang at the end, for disabling it.
SCRIPT_PATH=$(readlink -f "${BASH_SOURCE[0]}")

# Ensure $HOME exists
if [ -z "$HOME" ]; then
	echo "❌ HOME variable not set!"
	exit 1
fi

# Convert arguments to operations
if [ "$#" -gt 3 ]; then
	echo "ℹ️  Usage:"
	echo "  $0 [Author] [Repository] [SSH/HTTPS]"
	echo "     All optional, but must be in this order."
	exit 1
fi

echo "ℹ️  Your inputs:"

case "$#" in
3)
	AUTHOR="$1"
	echo "   Author: $AUTHOR"
	REPO="$2"
	echo "   Repository: $REPO"
	METHOD="$3"
	echo "   Method (ssh/HTTPS): $METHOD"
	;;
2)
	AUTHOR="$1"
	echo "   Author: $AUTHOR"
	REPO="$2"
	echo "   Repository: $REPO"
	read -rp "   Method (ssh/HTTPS): " METHOD
	;;
1)
	AUTHOR="$1"
	echo "   Author: $AUTHOR"
	read -rp "   Repository: " REPO
	read -rp "   Method (ssh/HTTPS): " METHOD
	;;
0)
	read -rp "   Author: " AUTHOR
	read -rp "   Repository: " REPO
	read -rp "   Method (ssh/HTTPS): " METHOD
	;;
esac

METHOD="${METHOD,,}"
if [ "$METHOD" = "ssh" ]; then
	METHOD="SSH"
	CLONE_URL="git@github.com:$AUTHOR/$REPO.git"
else
	METHOD="HTTPS"
	CLONE_URL="https://github.com/$AUTHOR/$REPO.git"
fi
echo

# Build repo directory and clone
REPO_DIR="$HOME/GitHub/$AUTHOR/$REPO"
if [ -e "$REPO_DIR" ]; then
	echo "⚠️  Repo folder exists. Aborting..."
	echo "ℹ️  Move or delete:"
	echo "   $REPO_DIR"
	exit 1
else
	echo "================ ℹ️  Git progress ℹ️  ================"
	git clone "$CLONE_URL" "$REPO_DIR/"
	echo "================ ℹ️  Git progress ℹ️  ================"
	echo
	echo "✅ Successfully cloned '$AUTHOR/$REPO'"
	echo "ℹ️  Repo directory can be found at:"
	echo "   $REPO_DIR"
fi

# Hang

KEEP_OPEN=false

if [ "$KEEP_OPEN" = true ]; then
	echo
	read -p "Press 'Enter' to exit / Type 'disable' to disable hanging (local only): " response
	if [ "$response" = "disable" ]; then
		sed -i 's/^KEEP_OPEN=true/KEEP_OPEN=false/' "$SCRIPT_PATH"
		echo
		echo "KEEP_OPEN set to false"
		echo "Change 'KEEP_OPEN=true' to enable"
		echo
		for i in {5..1}; do
			echo -n "Exiting in $i..."
			sleep 1
			echo -ne "\r"
		done
		echo "Exiting now.        "
	fi
fi
