#!/usr/bin/env bash

set -e

# Ensure $HOME exists
if [ -z "$HOME" ]; then
	echo "❌ HOME variable not set!"
	exit 1
fi

# Convert argument count to operations
if [ "$#" -gt 3 ]; then
	echo "ℹ️  Usage:"
	echo "  $0 [Author] [Repository] [SSH/HTTPS]"
	exit 1
fi

echo "ℹ️  Your inputs:"

case "$#" in
3)
	AUTHOR="$1"
	echo "   Author: $AUTHOR"
	REPO="$2"
	echo "   Repository: $REPO"
	METHOD="$3"
	echo "   Method (ssh/HTTPS): $METHOD"
	;;
2)
	AUTHOR="$1"
	echo "   Author: $AUTHOR"
	REPO="$2"
	echo "   Repository: $REPO"
	read -rp "   Method (ssh/HTTPS): " METHOD
	;;
1)
	AUTHOR="$1"
	echo "   Author: $AUTHOR"
	read -rp "   Repository: " REPO
	read -rp "   Method (ssh/HTTPS): " METHOD
	;;
0)
	read -rp "   Author: " AUTHOR
	read -rp "   Repository: " REPO
	read -rp "   Method (ssh/HTTPS): " METHOD
	;;
esac

METHOD="${METHOD,,}"
if [ "$METHOD" = "ssh" ]; then
	METHOD="SSH"
	CLONE_URL="git@github.com:$AUTHOR/$REPO.git"
else
	METHOD="HTTPS"
	CLONE_URL="https://github.com/$AUTHOR/$REPO.git"
fi
echo

# Build repo directory and clone
REPO_DIR="$HOME/GitHub/$AUTHOR/$REPO"
if [ -d "$REPO_DIR" ]; then
	echo -e "⚠️  Repo folder exists. Aborting..."
	echo -e "ℹ️  Move or delete the folder '$REPO_DIR'"
	exit 1
else
	mkdir -p "$REPO_DIR"
	echo -e "================ ℹ️  Git progress ℹ️  ================"
	git clone "$CLONE_URL" "$REPO_DIR/"
	echo -e "================ ℹ️  Git progress ℹ️  ================"
	echo
	echo -e "✅ Successfully cloned '$AUTHOR/$REPO'"
	echo -e "ℹ️  Repo directory can be found at '$REPO_DIR'"
fi
