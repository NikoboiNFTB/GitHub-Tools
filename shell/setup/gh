#!/usr/bin/env bash

set -euo pipefail

# Helpers
die() {
	echo "❌ $1" >&2
	exit 1
}
info() { echo "ℹ️  $1"; }
ok() { echo "✅ $1"; }

info "Running preflight checks..."

# Check required commands
for cmd in gh ssh; do
	command -v "$cmd" >/dev/null || die "$cmd is required but not installed."
	ok "$cmd found"
done

# gh setup
gh auth login
