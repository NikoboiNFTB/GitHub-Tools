#!/usr/bin/env bash

set -e

# Determine original user (robust)
if [ -n "$SUDO_USER" ]; then
    # Script run via sudo
    REAL_USER="$SUDO_USER"
elif [ "$(id -u)" -ne 0 ]; then
    # Non-root user
    REAL_USER="$(whoami)"
else
    # Root login (including su -)
    # Try to detect original user via parent process
    PARENT_USER=$(ps -o user= -p $PPID)
    if [ -n "$PARENT_USER" ] && [ "$PARENT_USER" != "root" ]; then
        REAL_USER="$PARENT_USER"
    else
        echo "❌ Cannot reliably detect original user. Exiting."
        exit 1
    fi
fi

# Lookup home directory from /etc/passwd
REAL_HOME=$(getent passwd "$REAL_USER" | cut -d: -f6)
[ -z "$REAL_HOME" ] && REAL_HOME="/home/$REAL_USER"
export HOME="$REAL_HOME"

echo "ℹ️  Running on behalf of: $REAL_USER"
echo "ℹ️  HOME directory set to: $HOME"

# Ensure HOME exists
if [ -z "$HOME" ] || [ ! -d "$HOME" ]; then
    echo "❌ HOME variable not set or directory does not exist!";
    exit 1;
fi

# Definitions
GITHUB_DIR="$HOME/GitHub"
AUTHOR="NikoboiNFTB"
AUTHOR_DIR="$GITHUB_DIR/$AUTHOR"
GIT_REPO="$AUTHOR_DIR/GitHub-Tools/"
PROTON_REPO="$AUTHOR_DIR/Proton-VPN/"
GP8_REPO="$AUTHOR_DIR/Guitar-Pro-On-Linux/"
IO_REPO="$AUTHOR_DIR/nikoboinftb.github.io/"

# Copy files
if [ "$EUID" -eq 0 ]; then
    # Copy to /usr/bin/
    cp "$GIT_REPO/shell/git/setup/automation" "/usr/bin/git-automation"
    cp "$GIT_REPO/shell/git/setup/workflow" "/usr/bin/git-workflow"
else
    # Copy to $io

    # GitHub-Tools/git/
    cp "$GIT_REPO/shell/git/setup/automation" "$IO_REPO/shell/git/setup/automation"
    cp "$GIT_REPO/shell/git/setup/gh" "$IO_REPO/shell/git/setup/gh"
    cp "$GIT_REPO/shell/git/setup/git" "$IO_REPO/shell/git/setup/git"
    cp "$GIT_REPO/shell/git/setup/workflow" "$IO_REPO/shell/git/setup/workflow"

    # GP8/
    cp "$GP8_REPO/install" "$IO_REPO/shell/gp8/install"

    # Proton/
    cp "$PROTON_REPO/install-icons" "$IO_REPO/shell/proton/install-icons"
    cp "$PROTON_REPO/setup" "$IO_REPO/shell/proton/setup"

    # GitHub-Tools/utils/
    cp "$GIT_REPO/shell/utils/compare" "$IO_REPO/shell/utils/compare"
    cp "$GIT_REPO/shell/utils/find-file" "$IO_REPO/shell/utils/find-file"
    cp "$GIT_REPO/shell/utils/find-.-filter-files" "$IO_REPO/shell/utils/find-.-filter-files"
    cp "$GIT_REPO/shell/utils/find-string" "$IO_REPO/shell/utils/find-string"
    cp "$GIT_REPO/shell/utils/sort" "$IO_REPO/shell/utils/sort"
    cp "$GIT_REPO/shell/utils/SORTME.txt" "$IO_REPO/shell/utils/SORTME.txt"
fi
