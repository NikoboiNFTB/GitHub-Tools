#!/usr/bin/env bash

set -e

# Ensure $HOME exists
if [ -z "$HOME" ]; then
	echo "❌ HOME variable not set!"
	exit 1
fi

SSH_DIR="$HOME/.ssh"
BACKUP_DIR="$HOME/.ssh.bak"

echo "Enabling SSH..."

[ -f "$BACKUP_DIR/id_ed25519_github" ] && mv -f "$BACKUP_DIR/id_ed25519_github" "$SSH_DIR/"
[ -f "$BACKUP_DIR/id_ed25519_github.pub" ] && mv -f "$BACKUP_DIR/id_ed25519_github.pub" "$SSH_DIR/"

chmod 600 "$SSH_DIR/id_ed25519_github" 2>/dev/null || true
chmod 644 "$SSH_DIR/id_ed25519_github.pub" 2>/dev/null || true

ssh-add "$SSH_DIR/id_ed25519_github" || echo "ssh-agent not running"

if [ -d "$BACKUP_DIR" ]; then
	rmdir "$BACKUP_DIR" 2>/dev/null || rm -rf "$BACKUP_DIR"
fi

echo "SSH enabled."
