#!/usr/bin/env bash

set -e

# Ensure $HOME exists
if [ -z "$HOME" ]; then
	echo "❌ HOME variable not set!"
	exit 1
fi

SSH_DIR="$HOME/.ssh"
BACKUP_DIR="$HOME/.ssh.bak"

mkdir -p "$BACKUP_DIR"

echo "Disabling SSH..."

[ -f "$SSH_DIR/id_ed25519_github" ] && mv -f "$SSH_DIR/id_ed25519_github" "$BACKUP_DIR/"
[ -f "$SSH_DIR/id_ed25519_github.pub" ] && mv -f "$SSH_DIR/id_ed25519_github.pub" "$BACKUP_DIR/"

ssh-add -D || true

echo "SSH disabled."
