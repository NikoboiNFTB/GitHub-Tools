#!/usr/bin/env bash

set -e

# Get the current folder name
current_dir=$(basename "$PWD")

# Determine what to add based on folder
if [ "$current_dir" = "auto" ]; then
	echo "Detected 'auto/' folder. Adding parent repo files..."
	git add ..
else
	echo "Adding current folder files..."
	git add .
fi

# Ask for commit message, use default if empty.
default_msg="Update"

read -rp "Enter commit message (Enter to use '$default_msg'): " commit_msg

if [ -z "$commit_msg" ]; then
	commit_msg="$default_msg"
fi

# Check for changes before committing/pushing
if git diff --quiet && git diff --cached --quiet; then
	echo "✅ Nothing to commit"
else
	if git commit -m "$commit_msg"; then
		if git push; then
			echo "✅ Successfully pushed"
		else
			echo "❌ Failed to push"
		fi
	else
		echo "❌ Failed to commit"
	fi
fi
