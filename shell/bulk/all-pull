#!/usr/bin/env bash

set -e

repos=()

# Add repos
for d in */; do
	if [ -d "$d/.git" ]; then
		repos+=("$d")
	fi
done

# Print that they're being pulled.
for d in "${repos[@]}"; do
	echo "ℹ️  Pulling $d"
done

echo

# Pull
for d in "${repos[@]}"; do
	(
		cd "$d" || exit 1

		set +e
		output=$(git pull 2>&1)
		status=$?
		set -e

		if [ "$status" -eq 0 ]; then
			if printf '%s\n' "$output" | grep -q "^Already up to date\."; then
				echo "✅ Already up to date: $d"
			else
				echo "✅ Successfully pulled $d"
			fi
		else
			echo "❌ Failed to pull $d"
		fi
	) &
done

wait
