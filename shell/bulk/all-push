#!/usr/bin/env bash

set -e

# Ask for commit message, use default if empty.
default_msg="Update"

read -rp "Enter commit message (Enter to use '$default_msg'): " commit_msg

if [ -z "$commit_msg" ]; then
	commit_msg="$default_msg"
fi

echo

repos=()

# Add repos
for d in */; do
	if [ -d "$d/.git" ]; then
		repos+=("$d")
	fi
done

# Print that they're being pushed.
for d in "${repos[@]}"; do
	echo "ℹ️  Pushing $d"
done

echo

# Push them.
for d in "${repos[@]}"; do
	(
		cd "$d" || exit
		git add . >/dev/null 2>&1
		if git diff --quiet && git diff --cached --quiet; then
			echo "✅ Nothing to commit: $d"
			exit 0
		fi
		if git commit -m "$commit_msg" >/dev/null 2>&1; then
			if git push >/dev/null 2>&1; then
				echo "✅ Successfully pushed $d"
			else
				echo "❌ Failed to push $d"
			fi
		else
			echo "❌ Failed to commit $d"
		fi
	) &
done

wait
